#include <WiFi.h>
#include <WebServer.h>
#include <ESP32Servo.h>

const char* ssid = "*************";
const char* password = "******";

WebServer server(80);
Servo myServo;

#define SERVO_PIN 19
#define SAFE_MIN_ANGLE 30
#define SAFE_MAX_ANGLE 140
#define REPS 10

volatile bool stopRequested = false;
int selectedExercise = 0;

void moveServoSafe(int angle) {
  angle = constrain(angle, SAFE_MIN_ANGLE, SAFE_MAX_ANGLE);
  myServo.write(angle);
}

bool safeDelay(unsigned long waitTime) {
  unsigned long start = millis();
  while (millis() - start < waitTime) {
    server.handleClient();   // 
    if (stopRequested) return false;
    delay(1);                // 
  }
  return true;
}


void doExercise(int ex) {
  stopRequested = false;

  for (int i = 0; i < REPS; i++) {

    if (stopRequested) break;

    if (ex == 1) {               
      moveServoSafe(SAFE_MAX_ANGLE);
      if (!safeDelay(800)) break;

      moveServoSafe(SAFE_MIN_ANGLE);
      if (!safeDelay(800)) break;
    }

    else if (ex == 2) {           
      moveServoSafe(90);
      if (!safeDelay(800)) break;

      moveServoSafe(SAFE_MIN_ANGLE);
      if (!safeDelay(800)) break;
    }

    else if (ex == 3) {          
      moveServoSafe(SAFE_MAX_ANGLE);
      if (!safeDelay(1600)) break;

      moveServoSafe(SAFE_MIN_ANGLE);
      if (!safeDelay(800)) break;
    }
  }

  moveServoSafe(SAFE_MIN_ANGLE);   
  selectedExercise = 0;
}


void handleRoot() {
  String html = R"rawliteral(
<!DOCTYPE html>
<html>
<head>
  <title>Hand Rehab Controller</title>
  <style>
    body { font-family: Arial; text-align: center; margin-top: 40px; }
    button { padding: 15px 30px; font-size: 18px; margin: 10px; }
    #status { font-size: 20px; margin-top: 20px; }
  </style>
</head>
<body>

<h2>Rehabilitation Exercise Control</h2>

<button onclick="fetch('/ex1')">Exercise 1</button><br>
<button onclick="fetch('/ex2')">Exercise 2</button><br>
<button onclick="fetch('/ex3')">Exercise 3</button><br><br>

<button style="background:red;color:white" onclick="fetch('/stop')">
STOP
</button>

</body>
</html>
)rawliteral";

  server.send(200, "text/html", html);
}

void handleEx1() { selectedExercise = 1; server.send(200, "text/plain", "Exercise 1"); }
void handleEx2() { selectedExercise = 2; server.send(200, "text/plain", "Exercise 2"); }
void handleEx3() { selectedExercise = 3; server.send(200, "text/plain", "Exercise 3"); }

void handleStop() {
  stopRequested = true;
  server.send(200, "text/plain", "STOPPED");
}

void setup() {
  Serial.begin(115200);

  myServo.setPeriodHertz(50);
  myServo.attach(SERVO_PIN, 500, 2400);
  moveServoSafe(SAFE_MIN_ANGLE);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
  }

  Serial.println(WiFi.localIP());

  server.on("/", handleRoot);
  server.on("/ex1", handleEx1);
  server.on("/ex2", handleEx2);
  server.on("/ex3", handleEx3);
  server.on("/stop", handleStop);

  server.begin();
}

void loop() {
  server.handleClient();

  if (selectedExercise != 0) {
    doExercise(selectedExercise);
  }
}
